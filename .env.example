# LLM provider: ollama | openai | stub
VITE_LLM_PROVIDER=ollama

# Ollama (local)
VITE_OLLAMA_BASE_URL=http://localhost:11434
VITE_LLM_MODEL=llama3.2

# OpenAI-compatible remote API (set VITE_LLM_PROVIDER=openai)
# VITE_LLM_ENDPOINT=https://api.openai.com/v1/chat/completions
# VITE_LLM_API_KEY=sk-your-key-here
# VITE_LLM_MODEL=gpt-4o

# Force offline stub (no network calls)
# VITE_LLM_PROVIDER=stub

# Map style mode:
# - osm-light (default, screenshot-like street map)
# - terrain-pmtiles (self-hosted PMTiles terrain test)
# VITE_MAP_STYLE_MODE=osm-light
# VITE_MAP_PMTILES_BASE_URL=http://localhost:3000/satellite.pmtiles
# VITE_MAP_PMTILES_DEM_URL=http://localhost:3000/dem.pmtiles
